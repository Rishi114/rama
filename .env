# RAMA AI Configuration
# Copy this to .env and fill in your values

# ============================================
# USER SETTINGS
# ============================================
USER_NAME=bhai
USER_LANGUAGE=en
WAKE_WORD=hey rama

# ============================================
# API KEYS (Optional)
# ============================================
# HUGGINGFACE_TOKEN=your_huggingface_token_here
# OPENAI_API_KEY=your_openai_key_here
# ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ============================================
# PATHS
# ============================================
DATA_PATH=./data
LOG_PATH=./data/logs
SKILLS_PATH=./data/skills

# ============================================
# VOICE SETTINGS
# ============================================
VOICE_RATE=150
VOICE_VOLUME=1.0
STT_TIMEOUT=5

# ============================================
# FEATURES
# ============================================
VOICE_ENABLED=true
SELF_LEARNING=true
MEMORY_ENABLED=true
KILOCODE_ENABLED=true
AUTO_UPDATE=true